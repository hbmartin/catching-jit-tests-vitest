{
  "threshold": 0,
  "mode": "strict",
  "minTokens": 50,
  "minLines": 5,
  "format": ["typescript"],
  "reporters": ["console", "markdown"],
  "output": "report",
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/coverage/**",
    "**/tests/**",
    "**/scripts/**",
    "**/evals/**",
    "**/.git/**",
    "**/.github/workflows/**",
    "**/.next/**",
    "**/report/**",
    "**/reports/**",
    "**/test/**",
    "**/*.json",
    "**/*.tsx",
    "**/*.test.ts",
    "**/*.css",
    "**/*.md",
    "**/*.yml",
    "**/*.yaml"
  ],
  "maxSize": "512kb",
  "absolute": false,
  "noColors": true,
  "silent": false
}
