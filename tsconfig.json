{
  "extends": "@sindresorhus/tsconfig",
  "compilerOptions": {
    "strict": true,
    "rootDir": "source",
    "outDir": "dist",
    "types": ["node"],
    "noUncheckedSideEffectImports": true,
    "libReplacement": false,
    "noUnusedLocals": false,
    "erasableSyntaxOnly": false
  },
  "include": ["source"]
}
